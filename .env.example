# Turso (SQLite cloud) — https://turso.tech
EXPO_PUBLIC_TURSO_URL=libsql://your-db-name.turso.io
EXPO_PUBLIC_TURSO_AUTH_TOKEN=your-turso-auth-token

# Claude API — https://console.anthropic.com
# WARNING: EXPO_PUBLIC_* vars are bundled into the client app and are
# extractable by anyone who downloads it. Fine for local/personal use,
# not safe for a public release — route this through a backend instead.
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-your-api-key
